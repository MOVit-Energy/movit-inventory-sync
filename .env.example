# Shopify shop domain
SHOPIFY_SHOP=movitenergy.myshopify.com

# Shopify Custom App OAuth credentials (client_credentials flow).
# App scopes required: write_products (covers read_products + price list access), read_inventory
# Note: there is no separate `read_price_lists` scope — price lists are covered by read_products.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Location GIDs used by the inventory sync
LOCATION_ID_B2C=gid://shopify/Location/000000000000
LOCATION_ID_B2B=gid://shopify/Location/000000000000

# Bearer token for the manual /api/sync-all endpoint (?token=...)
SYNC_TOKEN=

# Cron auth for /api/cron/sync-b2b-prices.
# Vercel cron automatically sends `Authorization: Bearer ${CRON_SECRET}`.
# Generate with: openssl rand -hex 24
CRON_SECRET=

# Optional: Slack Incoming Webhook for failure / userError alerts. Leave empty to disable.
SLACK_WEBHOOK_URL=

# Optional: override the B2B "B2B All" price list GID.
# Defaults to gid://shopify/PriceList/43564958073 if unset.
B2B_PRICE_LIST_ID=gid://shopify/PriceList/43564958073
